# ─── Product Info password ───────────────────────────────────────────────────
# The password required to access the Product Info section.
PRODUCT_INFO_PASSWORD=grapes

# ─── Website REST API (Ask Me Anything) ──────────────────────────────────────
# Your main website's API base URL. Used by the AMA adapter to search for
# content from your live website. Leave blank to disable website search.
WEBSITE_API_URL=

# Optional API key if your website API requires authentication.
WEBSITE_API_KEY=

# ─── WooCommerce (Postcode Checker) ──────────────────────────────────────────
# Your WooCommerce store URL (no trailing slash)
WOOCOMMERCE_URL=https://yoursite.com
# WooCommerce REST API consumer key and secret
# Generate at: WooCommerce → Settings → Advanced → REST API
WOOCOMMERCE_KEY=ck_xxxxxxxxxxxxxxxxxxxx
WOOCOMMERCE_SECRET=cs_xxxxxxxxxxxxxxxxxxxx

# ─── Future integrations ─────────────────────────────────────────────────────
# Uncomment and populate when ready to vary up:

# Claude / Anthropic (for AI-powered Ask Me Anything answers)
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Admin ────────────────────────────────────────────────────────────────────
# Password for the /admin section
ADMIN_PASSWORD=

# ─── Vercel Blob (product images) ────────────────────────────────────────────
# Auto-set by Vercel when you add the Blob store. Also set BLOB_INDEX_URL to
# the public URL of products/index.json after the first deploy.
BLOB_READ_WRITE_TOKEN=
BLOB_INDEX_URL=

# CMS (e.g. Sanity, Contentful, Hygraph)
# CMS_API_URL=
# CMS_API_TOKEN=

# Cloud storage (for product assets)
# STORAGE_BUCKET_URL=
